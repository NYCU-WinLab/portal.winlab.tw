{
  "name": "portal.winlab.tw",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.1.18",
    "turbo": "^2.8.17",
    "typescript": "6.0.3"
  },
  "packageManager": "bun@1.3.11",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@tanstack/react-query": "^5.99.2",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.8.0",
    "shadcn": "^4.3.1",
    "sonner": "^2.0.7",
    "tw-animate-css": "^1.4.0"
  },
  "overrides": {
    "tslib": "^2.8.1",
    "fast-uri": "^3.1.2",
    "ws": "^8.21.0",
    "esbuild": "^0.28.1",
    "hono": "^4.12.25"
  }
}
