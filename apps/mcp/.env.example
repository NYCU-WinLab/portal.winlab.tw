# Public base URL for this deployment. Used to build OAuth metadata URLs.
# Dev: http://localhost:3001
# Prod: https://mcp.winlab.tw
NEXT_PUBLIC_BASE_URL=http://localhost:3001

# Supabase — shared with portal
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Service role (server-only). Not strictly required by MCP tools since
# they run under the user's bearer token, but handy for future admin jobs.
SUPABASE_SERVICE_ROLE_KEY=
