NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only. Bypasses RLS — never expose to the browser.
# Supabase Dashboard → Project Settings → API Keys → Secret keys
SUPABASE_SECRET_KEY=

# Shared secret for the gallery mention notification API.
# Used by Google Apps Script to fetch unnotified @mentions and mark them sent.
# Generate with: openssl rand -hex 32
GALLERY_API_SECRET=
