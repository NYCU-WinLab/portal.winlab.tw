{
  "name": "gallery",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "sync-ffmpeg": "node ./scripts/sync-ffmpeg-core.mjs",
    "predev": "bun run sync-ffmpeg",
    "prebuild": "bun run sync-ffmpeg",
    "dev": "next dev --turbopack --port 3005",
    "dev:webpack": "next dev --webpack --port 3005",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@ffmpeg/core": "0.12.10",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.220.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.220.0",
    "@opentelemetry/sdk-logs": "^0.220.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.104.0",
    "@tabler/icons-react": "^3.41.1",
    "@vercel/otel": "^2.1.3",
    "@workspace/ui": "workspace:*",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/bun": "^1.3.13",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@workspace/eslint-config": "workspace:^",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^10.6.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^6.0.3"
  }
}
