NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only. Bypasses RLS — never expose to the browser.
# Supabase Dashboard → Project Settings → API Keys → Secret keys
# (legacy name: service_role key; same capability, new UI naming).
SUPABASE_SECRET_KEY=

# Resend → notifications.winlab.tw. Auto-synced via Vercel integration in prod.
RESEND_API_KEY=

# Shared secret between Vercel Cron and the cron route handler.
# Vercel injects `Authorization: Bearer $CRON_SECRET` on scheduled invocations.
CRON_SECRET=

# Public site URL used when rendering links in outgoing emails.
# Defaults to https://portal.winlab.tw if not set.
NEXT_PUBLIC_SITE_URL=
