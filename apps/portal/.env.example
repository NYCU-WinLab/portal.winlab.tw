NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only. Bypasses RLS — never expose to the browser.
# Supabase Dashboard → Project Settings → API Keys → Secret keys
# (legacy name: service_role key; same capability, new UI naming).
SUPABASE_SECRET_KEY=

# Resend → notifications.winlab.tw. Auto-synced via Vercel integration in prod.
RESEND_API_KEY=

# Shared secret between Vercel Cron and the cron route handler.
# Vercel injects `Authorization: Bearer $CRON_SECRET` on scheduled invocations.
CRON_SECRET=

# Public site URL used when rendering links in outgoing emails.
# Defaults to https://portal.winlab.tw if not set.
NEXT_PUBLIC_SITE_URL=

# NextCloud service account for PPT/video uploads from meetings.
# Create an app password under the portal-bot account in NextCloud Settings → Security.
NEXTCLOUD_URL=
NEXTCLOUD_USERNAME=
NEXTCLOUD_APP_PASSWORD=

# Shared secret for the bulletin board notification API.
# Used by Google Apps Script to fetch unnotified announcements and mark them sent.
# Generate with: openssl rand -hex 32
BULLETIN_API_SECRET=

# Shared secret for the meetings schedule API.
# Used by the Google Apps Script reminder mailer to fetch the schedule without a
# login cookie. Send as `Authorization: Bearer $MEETINGS_API_SECRET`.
# Generate with: openssl rand -hex 32
MEETINGS_API_SECRET=

# Keycloak admin API, used by /profile self-service edits. The client needs
# "Service accounts roles" enabled with realm-management → manage-users
# assigned. Server-only — never expose to the browser. When unset, the
# profile edit section is hidden and the rest of /profile still works.
KEYCLOAK_URL=
KEYCLOAK_REALM=
KEYCLOAK_ADMIN_CLIENT_ID=
KEYCLOAK_ADMIN_CLIENT_SECRET=

# Sensorium (sensorium.zyx.tw) observability producer. Unset locally on
# purpose — instrumentation.ts no-ops entirely when this is empty, so plain
# `bun run dev` never tries to export telemetry anywhere.
# OTEL_EXPORTER_OTLP_ENDPOINT=https://sensorium.zyx.tw
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer <token>
# OTEL_SERVICE_NAME=portal
# OTEL_RESOURCE_ATTRIBUTES=service.namespace=portal-winlab
